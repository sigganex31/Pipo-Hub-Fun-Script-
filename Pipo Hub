local PipoLib = loadstring(game:HttpGet("[https://raw.githubusercontent.com/sigganex31/updated-Pipo-Hub-Gui/refs/heads/main/Gui%20exe%20rar%20mp4%20mp3%20png?raw=true](https://raw.githubusercontent.com/sigganex31/updated-Pipo-Hub-Gui/refs/heads/main/Gui%20exe%20rar%20mp4%20mp3%20png?raw=true)"))()
local MainFrame = PipoLib:CreateWindow("PIPO HUB - GOD MODE")

local function AddButton(name, callback)
    local btn = Instance.new("TextButton", MainFrame)
    btn.Size = UDim2.new(0.9, 0, 0, 35)
    btn.Position = UDim2.new(0.05, 0, 0.15 + (#MainFrame:GetChildren() * 0.06), 0)
    btn.Text = name
    btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btn.TextColor3 = Color3.new(1, 1, 1)
    btn.MouseButton1Click:Connect(callback)
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 5)
end

AddButton("Hız: 100", function() game.Players.LocalPlayer.Character.Humanoid.WalkSpeed = 100 end)
AddButton("Gravity: 0", function() workspace.Gravity = 0 end)
AddButton("Noclip: ON", function() 
    game:GetService("RunService").Stepped:Connect(function()
        if game.Players.LocalPlayer.Character then
            for _, p in pairs(game.Players.LocalPlayer.Character:GetChildren()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end
    end)
end)
